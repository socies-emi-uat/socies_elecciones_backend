# ==================================================
# 📌 CONFIGURACIÓN BASE DE DATOS POSTGRES (NEON.TECH)
# ==================================================
# ¡Reemplaza estos valores con los reales en tu .env local!
POSTGRES_HOST=ep-nombre-dummy-123.us-east-1.aws.neon.tech
POSTGRES_DATABASE=nombre_bd_dummy
POSTGRES_USER=usuario_dummy
POSTGRES_PASSWORD=contraseña_super_secreta_dummy  # No compartir esto
# Opciones adicionales (SSL es obligatorio en Neon)
POSTGRES_SSLMODE=require  # Opciones: require, verify-full, etc.

# ==================================================
# 🔐 CONFIGURACIÓN JWT (TOKENS DE AUTENTICACIÓN)
# ==================================================
JWT_SECRET=clave_secreta_larga_y_compleja_123!@#  # Debe ser segura
JWT_EXPIRATION=86400000  # Tiempo en milisegundos (ej: 1 día = 86400000 ms)

# ==================================================
# 🌐 CONFIGURACIÓN SERVIDOR/APP
# ==================================================
SERVER_PORT=8080  # Puerto donde corre Spring Boot
APP_FRONTEND_URL=http://localhost:3000  # URL de tu frontend (para CORS)

# ==================================================
# 🛠️ ENTORNO (development, production, etc.)
# ==================================================
SPRING_PROFILES_ACTIVE=development